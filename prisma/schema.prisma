// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE COMMUNITY & USER MODELS
// ============================================================================

model Community {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  slug         String   @unique
  domain       String?  @unique
  description  String?
  colorPrimary String   @default("#46A8CC")
  colorAccent  String   @default("#A51E30")
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  memberships            UserCommunityMembership[]
  articles               Article[]
  recipes                Recipe[]
  events                 Event[]
  eventSeries            EventSeries[]
  stores                 Store[]
  organizations          Organization[]
  organizationFormSubmissions OrganizationFormSubmission[]
  locations              Location[]
  marketplaceListings    MarketplaceListing[]
  helpWantedPosts        HelpWantedPost[]
  roadmapIdeas           RoadmapIdea[]
  roadmapBallots         RoadmapRankingBallot[]
  domainInfluenceWeights DomainInfluenceWeight[]
  homepageSections       HomepageSection[]
  domains                TenantDomain[]
  categories             Category[]
  siteSettings           SiteSetting[]
  tenantCoverageAreas    TenantCoverageArea[]

  @@map("communities")
}

model TenantDomain {
  id          String             @id @default(uuid()) @db.Uuid
  communityId String             @db.Uuid
  domain      String             @unique
  isPrimary   Boolean            @default(false)
  status      TenantDomainStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@map("tenant_domains")
}

enum TenantDomainStatus {
  PENDING
  ACTIVE
  DISABLED
}

model User {
  id                String     @id @default(uuid()) @db.Uuid
  email             String     @unique
  passwordHash      String?
  firstName         String
  lastName          String
  dateOfBirth       DateTime?
  profilePhotoUrl   String?
  bio               String?
  isDirectoryListed Boolean    @default(false)
  trustLevel        TrustLevel @default(ANONYMOUS)
  isIdentityLocked  Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  memberships              UserCommunityMembership[]
  vouchesGiven             VouchRecord[]             @relation("voucherUser")
  vouchesReceived          VouchRecord[]             @relation("vouchedUser")
  articles                 Article[]
  recipes                  Recipe[]
  comments                 Comment[]
  eventsSubmitted          Event[]
  eventSeriesCreated       EventSeries[]
  marketplaceListings      MarketplaceListing[]
  helpWantedPosts          HelpWantedPost[]
  roadmapIdeas             RoadmapIdea[]
  roadmapRankingBallots    RoadmapRankingBallot[]
  domainInfluenceWeights   DomainInfluenceWeight[]
  trustAuditLogsAsActor    TrustAuditLog[]           @relation("actorUser")
  trustAuditLogsAsTarget   TrustAuditLog[]           @relation("targetUser")
  bannedEmailsCreated      BannedEmail[]             @relation("bannedByUser")
  bannedEmailsRemoved      BannedEmail[]             @relation("unbannedByUser")
  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]
  userBlocksInitiated      UserBlock[]               @relation("blockerUser")
  userBlocksReceived       UserBlock[]               @relation("blockedUser")
  homepagePinnedItems      HomepagePinnedItem[]
  loginEvents              LoginEvent[]
  activityLogs             ActivityLog[]
  ownedStores              Store[]                   @relation("storeOwner")
  approvedStores           Store[]                   @relation("storeApprovedBy")
  storeMemberships         StoreMember[]
  createdOrganizations     Organization[]            @relation("organizationCreatedBy")
  approvedOrganizations    Organization[]            @relation("organizationApprovedBy")
  organizationMemberships  OrganizationMembership[]
  organizationContacts     OrganizationContact[]
  createdOrganizationForms OrganizationForm[]        @relation("organizationFormCreatedBy")
  updatedOrganizationForms OrganizationForm[]        @relation("organizationFormUpdatedBy")
  organizationFormSubmissions OrganizationFormSubmission[]
  placeRelationships       UserPlaceRelationship[]

  @@map("users")
}

enum TrustLevel {
  ANONYMOUS
  REGISTERED
  TRUSTED
  SUSPENDED
}

enum OrganizationDirectoryGroup {
  BUSINESS
  GOVERNMENT
  ORGANIZATION
}

enum OrganizationStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrganizationMembershipRole {
  OWNER
  MANAGER
  STAFF
  BOARD_MEMBER
  VOLUNTEER
  PASTOR
  OFFICIAL
  ADMINISTRATOR
}

enum OrganizationMembershipStatus {
  PENDING
  ACTIVE
  REJECTED
  REMOVED
}

enum OrganizationFormStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum OrganizationFormQuestionType {
  TEXT_SHORT
  TEXT_LONG
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}

// ============================================================================
// COMMUNITY MEMBERSHIP & TRUST
// ============================================================================

model UserCommunityMembership {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  communityId String         @db.Uuid
  role        MembershipRole @default(READER)
  joinedAt    DateTime       @default(now())

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@map("user_community_memberships")
}

enum MembershipRole {
  READER
  CONTRIBUTOR
  STAFF_WRITER
  EDITOR
  ADMIN
  SUPER_ADMIN
}

enum PlaceType {
  BOROUGH
  TOWNSHIP
  TOWN
  CITY
  COUNTY
  REGION
  STATE
  COUNTRY
}

enum TenantCoverageType {
  PRIMARY
  SECONDARY
  EMERGING
  WATCHLIST
}

enum UserPlaceRelationshipType {
  CURRENT_RESIDENT
  FORMER_RESIDENT
  FROM_HERE
  FAMILY_IN
  WORKS_IN
  OWNS_PROPERTY_IN
  CARES_ABOUT
}

enum UserPlaceSource {
  USER_SELECTED
  ADMIN_SET
  MIGRATED
}

enum ObservedGeoReviewStatus {
  UNMATCHED
  MATCHED_TO_PLACE
  IGNORE
  READY_FOR_CURATION
  PROMOTED
}

model Place {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  displayName    String
  slug           String    @unique
  type           PlaceType
  countryCode    String
  admin1Code     String?
  admin1Name     String?
  admin2Name     String?
  parentPlaceId  String?   @db.Uuid
  isSelectable   Boolean   @default(true)
  isActive       Boolean   @default(true)
  latitude       Decimal?  @db.Decimal(9, 6)
  longitude      Decimal?  @db.Decimal(9, 6)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  parentPlace            Place?                  @relation("PlaceHierarchy", fields: [parentPlaceId], references: [id], onDelete: SetNull)
  childPlaces            Place[]                 @relation("PlaceHierarchy")
  aliases                PlaceAlias[]
  tenantCoverageAreas    TenantCoverageArea[]
  userRelationships      UserPlaceRelationship[]
  matchedObservedGeos    ObservedGeoLocation[]

  @@index([type])
  @@index([countryCode])
  @@index([parentPlaceId])
  @@index([countryCode, admin1Code])
  @@map("places")
}

model PlaceAlias {
  id           String   @id @default(uuid()) @db.Uuid
  placeId      String   @db.Uuid
  alias        String
  aliasType    String?
  isSearchable Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, alias])
  @@index([placeId])
  @@index([alias])
  @@map("place_aliases")
}

model TenantCoverageArea {
  id           String             @id @default(uuid()) @db.Uuid
  communityId  String             @db.Uuid
  placeId      String             @db.Uuid
  coverageType TenantCoverageType @default(SECONDARY)
  isPrimary    Boolean            @default(false)
  isActive     Boolean            @default(true)
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  // Relations
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  place     Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([communityId, placeId])
  @@index([communityId])
  @@index([placeId])
  @@index([coverageType])
  @@map("tenant_coverage_areas")
}

model UserPlaceRelationship {
  id                   String                    @id @default(uuid()) @db.Uuid
  userId               String                    @db.Uuid
  placeId              String?                   @db.Uuid
  relationshipType     UserPlaceRelationshipType
  isPrimary            Boolean                   @default(false)
  isCurrent            Boolean                   @default(false)
  fallbackLocationText String?
  source               UserPlaceSource           @default(USER_SELECTED)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place? @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([placeId])
  @@index([relationshipType])
  @@map("user_place_relationships")
}

model ObservedGeoLocation {
  id                String                  @id @default(uuid()) @db.Uuid
  normalizedLabel   String
  city              String?
  region            String?
  country           String?
  matchedPlaceId    String?                 @db.Uuid
  reviewStatus      ObservedGeoReviewStatus @default(UNMATCHED)
  firstSeenAt       DateTime
  lastSeenAt        DateTime
  loginCount        Int                     @default(0)
  distinctUserCount Int                     @default(0)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  // Relations
  matchedPlace Place? @relation(fields: [matchedPlaceId], references: [id], onDelete: SetNull)

  @@unique([normalizedLabel])
  @@index([matchedPlaceId])
  @@index([reviewStatus])
  @@map("observed_geo_locations")
}

model VouchRecord {
  id            String   @id @default(uuid()) @db.Uuid
  voucherUserId String   @db.Uuid
  vouchedUserId String   @db.Uuid
  createdAt     DateTime @default(now())

  // Relations
  voucherUser User @relation("voucherUser", fields: [voucherUserId], references: [id], onDelete: Cascade)
  vouchedUser User @relation("vouchedUser", fields: [vouchedUserId], references: [id], onDelete: Cascade)

  @@unique([voucherUserId, vouchedUserId])
  @@map("vouch_records")
}

model TrustAuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  actorUserId  String      @db.Uuid
  targetUserId String      @db.Uuid
  action       TrustAction
  reason       String?
  timestamp    DateTime    @default(now())

  // Relations
  actorUser  User @relation("actorUser", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUser User @relation("targetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@map("trust_audit_logs")
}

enum TrustAction {
  TRUST_GRANTED
  TRUST_REVOKED
  SUSPENDED
  REINSTATED
  BANNED
  UNBANNED
  IDENTITY_MODIFIED
}

model BannedEmail {
  id               String    @id @default(uuid()) @db.Uuid
  email            String    @unique
  bannedByUserId   String    @db.Uuid
  bannedAt         DateTime  @default(now())
  unbannedByUserId String?   @db.Uuid
  unbannedAt       DateTime?

  // Relations
  bannedByUser   User  @relation("bannedByUser", fields: [bannedByUserId], references: [id], onDelete: Cascade)
  unbannedByUser User? @relation("unbannedByUser", fields: [unbannedByUserId], references: [id], onDelete: SetNull)

  @@map("banned_emails")
}

// ============================================================================
// DIRECTORY / ORGANIZATIONS
// ============================================================================

model Organization {
  id                   String                     @id @default(uuid()) @db.Uuid
  communityId          String                     @db.Uuid
  createdByUserId      String                     @db.Uuid
  approvedByUserId     String?                    @db.Uuid
  name                 String
  slug                 String
  description          String?
  logoUrl              String?
  bannerUrl            String?
  websiteUrl           String?
  contactEmail         String?
  contactPhone         String?
  directoryGroup       OrganizationDirectoryGroup
  organizationType     String
  isPublicMemberRoster Boolean                    @default(false)
  status               OrganizationStatus         @default(PENDING_APPROVAL)
  approvedAt           DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  // Relations
  community   Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdBy   User                     @relation("organizationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  approvedBy  User?                    @relation("organizationApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  memberships OrganizationMembership[]
  locations   OrganizationLocation[]
  departments OrganizationDepartment[]
  contacts    OrganizationContact[]
  events      Event[]
  eventSeries EventSeries[]
  forms       OrganizationForm[]
  formSubmissions OrganizationFormSubmission[]

  @@unique([communityId, slug])
  @@index([communityId])
  @@index([createdByUserId])
  @@index([approvedByUserId])
  @@index([directoryGroup])
  @@index([organizationType])
  @@index([status])
  @@map("organizations")
}

model OrganizationMembership {
  id               String                       @id @default(uuid()) @db.Uuid
  organizationId   String                       @db.Uuid
  userId           String                       @db.Uuid
  role             OrganizationMembershipRole   @default(MANAGER)
  status           OrganizationMembershipStatus @default(PENDING)
  title            String?
  isPublic         Boolean                      @default(false)
  isPrimaryContact Boolean                      @default(false)
  joinedAt         DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@map("organization_memberships")
}

model OrganizationLocation {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  label          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  municipality   String?
  contactEmail   String?
  contactPhone   String?
  websiteUrl     String?
  hoursSummary   String?
  isPrimary      Boolean  @default(false)
  isPublic       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments  OrganizationDepartment[]
  contacts     OrganizationContact[]

  @@index([organizationId])
  @@index([municipality])
  @@map("organization_locations")
}

model OrganizationDepartment {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  locationId     String?  @db.Uuid
  name           String
  slug           String?
  description    String?
  contactEmail   String?
  contactPhone   String?
  websiteUrl     String?
  hoursSummary   String?
  isPublic       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     OrganizationLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  contacts     OrganizationContact[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([locationId])
  @@map("organization_departments")
}

model OrganizationContact {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  departmentId   String?  @db.Uuid
  locationId     String?  @db.Uuid
  userId         String?  @db.Uuid
  label          String?
  name           String?
  title          String?
  email          String?
  phone          String?
  websiteUrl     String?
  isPublic       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department   OrganizationDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  location     OrganizationLocation?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  user         User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([departmentId])
  @@index([locationId])
  @@index([userId])
  @@map("organization_contacts")
}

model OrganizationForm {
  id                String                 @id @default(uuid()) @db.Uuid
  organizationId    String                 @db.Uuid
  createdByUserId   String                 @db.Uuid
  updatedByUserId   String?                @db.Uuid
  title             String
  slug              String
  description       String?
  status            OrganizationFormStatus @default(DRAFT)
  isPubliclyListed  Boolean                @default(false)
  minimumTrustLevel TrustLevel             @default(REGISTERED)
  opensAt           DateTime?
  closesAt          DateTime?
  publishedAt       DateTime?
  closedAt          DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  organization Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User                        @relation("organizationFormCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  updatedBy    User?                       @relation("organizationFormUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  questions    OrganizationFormQuestion[]
  submissions  OrganizationFormSubmission[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("organization_forms")
}

model OrganizationFormQuestion {
  id         String                       @id @default(uuid()) @db.Uuid
  formId     String                       @db.Uuid
  prompt     String
  helpText   String?
  type       OrganizationFormQuestionType
  isRequired Boolean                      @default(false)
  sortOrder  Int                          @default(0)
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt

  form    OrganizationForm                 @relation(fields: [formId], references: [id], onDelete: Cascade)
  options OrganizationFormQuestionOption[]
  answers OrganizationFormAnswer[]

  @@index([formId, sortOrder])
  @@map("organization_form_questions")
}

model OrganizationFormQuestionOption {
  id         String                 @id @default(uuid()) @db.Uuid
  questionId String                 @db.Uuid
  label      String
  value      String
  sortOrder  Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  question OrganizationFormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  OrganizationFormAnswer[]

  @@index([questionId, sortOrder])
  @@map("organization_form_question_options")
}

model OrganizationFormSubmission {
  id             String   @id @default(uuid()) @db.Uuid
  formId         String   @db.Uuid
  organizationId String   @db.Uuid
  userId         String   @db.Uuid
  communityId    String   @db.Uuid
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  form         OrganizationForm       @relation(fields: [formId], references: [id], onDelete: Cascade)
  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  community    Community              @relation(fields: [communityId], references: [id], onDelete: Cascade)
  answers      OrganizationFormAnswer[]

  @@unique([formId, userId])
  @@index([organizationId, submittedAt])
  @@map("organization_form_submissions")
}

model OrganizationFormAnswer {
  id               String   @id @default(uuid()) @db.Uuid
  submissionId     String   @db.Uuid
  questionId       String   @db.Uuid
  selectedOptionId String?  @db.Uuid
  textValue        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  submission     OrganizationFormSubmission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question       OrganizationFormQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption OrganizationFormQuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@index([submissionId])
  @@index([questionId])
  @@index([selectedOptionId])
  @@map("organization_form_answers")
}

// ============================================================================
// ARTICLES & CONTENT
// ============================================================================

model Article {
  id                   String        @id @default(uuid()) @db.Uuid
  communityId          String        @db.Uuid
  authorUserId         String        @db.Uuid
  title                String
  slug                 String
  excerpt              String?
  body                 String
  featuredImageUrl     String?
  featuredImageCaption String?       @map("featured_image_caption")
  status               ArticleStatus @default(DRAFT)
  categoryId           String?       @db.Uuid
  publishedAt          DateTime?
  isFeatured           Boolean       @default(false)
  featuredOrder        Int?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relations
  community Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User         @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  category  Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags      ArticleTag[]
  comments  Comment[]

  @@unique([communityId, slug])
  @@index([communityId])
  @@index([authorUserId])
  @@index([categoryId])
  @@index([status])
  @@map("articles")
}

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  UNPUBLISHED
}

enum RecipeStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  UNPUBLISHED
}

enum RecipeNoteKind {
  COOK_NOTE
  SUBSTITUTION
  STORAGE
  SERVING
  TROUBLESHOOTING
}

enum RecipeMediaType {
  IMAGE
  VIDEO_EMBED
}

enum RecipeVideoProvider {
  YOUTUBE
  VIMEO
}

model Recipe {
  id                   String       @id @default(uuid()) @db.Uuid
  communityId          String       @db.Uuid
  authorUserId         String       @db.Uuid
  title                String
  slug                 String
  excerpt              String?
  introHtml            String?      @map("intro_html")
  featuredImageUrl     String?
  featuredImageCaption String?      @map("featured_image_caption")
  status               RecipeStatus @default(DRAFT)
  categoryId           String?      @db.Uuid
  yieldLabel           String?      @map("yield_label")
  prepMinutes          Int?         @map("prep_minutes")
  cookMinutes          Int?         @map("cook_minutes")
  totalMinutes         Int?         @map("total_minutes")
  servings             Int?
  sourceName           String?      @map("source_name")
  sourceUrl            String?      @map("source_url")
  structuredInputRaw   Json?        @map("structured_input_raw")
  publishedAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  community           Community                 @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author              User                      @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  category            Category?                 @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ingredientSections  RecipeIngredientSection[]
  ingredients         RecipeIngredient[]
  instructionSteps    RecipeInstructionStep[]
  notes               RecipeNote[]
  media               RecipeMedia[]

  @@unique([communityId, slug])
  @@index([communityId])
  @@index([authorUserId])
  @@index([categoryId])
  @@index([status])
  @@map("recipes")
}

model RecipeIngredientSection {
  id        String @id @default(uuid()) @db.Uuid
  recipeId  String @db.Uuid
  title     String?
  sortOrder Int    @default(0) @map("sort_order")

  recipe      Recipe             @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@index([recipeId, sortOrder])
  @@map("recipe_ingredient_sections")
}

model RecipeIngredient {
  id               String  @id @default(uuid()) @db.Uuid
  recipeId         String  @db.Uuid
  sectionId        String? @db.Uuid @map("section_id")
  sortOrder        Int     @default(0) @map("sort_order")
  amount           String?
  unit             String?
  ingredientName   String  @map("ingredient_name")
  preparationNote  String? @map("preparation_note")
  isOptional       Boolean @default(false) @map("is_optional")
  substitutionNote String? @map("substitution_note")

  recipe  Recipe                   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  section RecipeIngredientSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([recipeId, sortOrder])
  @@index([sectionId])
  @@map("recipe_ingredients")
}

model RecipeInstructionStep {
  id           String  @id @default(uuid()) @db.Uuid
  recipeId     String  @db.Uuid
  sortOrder    Int     @default(0) @map("sort_order")
  title        String?
  body         String
  timerMinutes Int?    @map("timer_minutes")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  media  RecipeMedia[]

  @@index([recipeId, sortOrder])
  @@map("recipe_instruction_steps")
}

model RecipeNote {
  id        String         @id @default(uuid()) @db.Uuid
  recipeId  String         @db.Uuid
  kind      RecipeNoteKind
  title     String?
  body      String
  sortOrder Int            @default(0) @map("sort_order")

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, sortOrder])
  @@map("recipe_notes")
}

model RecipeMedia {
  id            String              @id @default(uuid()) @db.Uuid
  recipeId      String              @db.Uuid
  stepId        String?             @db.Uuid @map("step_id")
  type          RecipeMediaType
  provider      RecipeVideoProvider?
  imageUrl      String?             @map("image_url")
  embedUrl      String?             @map("embed_url")
  caption       String?
  altText       String?             @map("alt_text")
  sortOrder     Int                 @default(0) @map("sort_order")
  createdAt     DateTime            @default(now()) @map("created_at")

  recipe Recipe                 @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  step   RecipeInstructionStep? @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([recipeId, sortOrder])
  @@index([stepId, sortOrder])
  @@map("recipe_media")
}

model Tag {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique
  slug String @unique

  // Relations
  articles ArticleTag[]

  @@map("tags")
}

model ArticleTag {
  articleId String @db.Uuid
  tagId     String @db.Uuid

  // Relations
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

model Category {
  id               String                @id @default(uuid()) @db.Uuid
  communityId      String?               @db.Uuid
  name             String
  slug             String
  contentModel     CategoryContentModel?
  minTrustLevel    TrustLevel            @default(ANONYMOUS)
  parentCategoryId String?               @db.Uuid
  sortOrder        Int                   @default(0)
  isArchived       Boolean               @default(false)

  // Relations
  community       Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  parentCategory  Category?  @relation("categoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: Cascade)
  childCategories Category[] @relation("categoryHierarchy")
  articles        Article[]
  recipes         Recipe[]

  @@index([communityId])
  @@index([parentCategoryId])
  @@map("categories")
}

enum CategoryContentModel {
  ARTICLE
  RECIPE
  EVENT
  HELP_WANTED
  MARKETPLACE
  MIXED
  PLANNED
}

model Comment {
  id              String        @id @default(uuid()) @db.Uuid
  articleId       String        @db.Uuid
  authorUserId    String        @db.Uuid
  parentCommentId String?       @db.Uuid
  body            String
  status          CommentStatus @default(APPROVED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  article       Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author        User      @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  parentComment Comment?  @relation("commentHierarchy", fields: [parentCommentId], references: [id], onDelete: Cascade)
  childComments Comment[] @relation("commentHierarchy")

  @@index([articleId])
  @@index([authorUserId])
  @@index([parentCommentId])
  @@map("comments")
}

enum CommentStatus {
  APPROVED
  PENDING
  HIDDEN
}

// ============================================================================
// EVENTS
// ============================================================================

model Event {
  id                String      @id @default(uuid()) @db.Uuid
  communityId       String      @db.Uuid
  submittedByUserId String      @db.Uuid
  organizationId    String?     @db.Uuid
  seriesId          String?     @db.Uuid
  locationId        String      @db.Uuid
  title             String
  venueLabel        String?
  description       String?
  startDatetime     DateTime
  endDatetime       DateTime?
  costText          String?
  contactInfo       String?
  isRecurring       Boolean     @default(false)
  recurrenceRule    String?
  seriesPosition    Int?
  seriesCount       Int?
  photoUrl          String?
  status            EventStatus @default(PENDING_REVIEW)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  community    Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  submittedBy  User          @relation(fields: [submittedByUserId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  series       EventSeries?  @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  location     Location      @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([communityId])
  @@index([submittedByUserId])
  @@index([organizationId])
  @@index([seriesId])
  @@index([locationId])
  @@index([status])
  @@map("events")
}

model EventSeries {
  id                String   @id @default(uuid()) @db.Uuid
  communityId       String   @db.Uuid
  createdByUserId   String   @db.Uuid
  organizationId    String?  @db.Uuid
  title             String
  summary           String?
  cadenceLabel      String
  intervalCount     Int      @default(1)
  occurrenceCount   Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  community     Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdBy     User          @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  events        Event[]

  @@index([communityId])
  @@index([createdByUserId])
  @@index([organizationId])
  @@map("event_series")
}

enum EventStatus {
  PENDING_REVIEW
  PUBLISHED
  UNPUBLISHED
}

model Location {
  id                   String                   @id @default(uuid()) @db.Uuid
  communityId          String                   @db.Uuid
  name                 String?
  addressLine1         String
  addressLine2         String?
  city                 String
  state                String
  postalCode           String?
  countryCode          String                   @default("US")
  normalizedAddressKey String
  latitude             Decimal?                 @db.Decimal(9, 6)
  longitude            Decimal?                 @db.Decimal(9, 6)
  validationStatus     LocationValidationStatus @default(UNVERIFIED)
  validatedAt          DateTime?
  googlePlaceId        String?
  uspsNormalized       Boolean                  @default(false)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  events    Event[]

  @@index([communityId])
  @@index([normalizedAddressKey])
  @@index([googlePlaceId])
  @@map("locations")
}

enum LocationValidationStatus {
  UNVERIFIED
  NORMALIZED
  VERIFIED
  NEEDS_REVIEW
}

// ============================================================================
// HELP WANTED
// ============================================================================

model HelpWantedPost {
  id               String                      @id @default(uuid()) @db.Uuid
  communityId      String                      @db.Uuid
  authorUserId     String                      @db.Uuid
  title            String
  description      String
  postingType      HelpWantedPostingType
  compensationType HelpWantedCompensationType?
  compensationText String?
  locationText     String?
  scheduleText     String?
  photoUrl         String?
  status           HelpWantedStatus            @default(PENDING_REVIEW)
  publishedAt      DateTime?
  filledAt         DateTime?
  closedAt         DateTime?
  expiresAt        DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  // Relations
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([authorUserId])
  @@index([postingType])
  @@index([status])
  @@map("help_wanted_posts")
}

enum HelpWantedPostingType {
  EMPLOYMENT
  SERVICE_REQUEST
  GIG_TASK
}

enum HelpWantedCompensationType {
  HOURLY
  SALARY
  FIXED
  NEGOTIABLE
  VOLUNTEER
  UNSPECIFIED
}

enum HelpWantedStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  FILLED
  CLOSED
  REJECTED
}

// ============================================================================
// COMMUNITY ROADMAP / FEATURE PRIORITIZATION
// ============================================================================

model RoadmapIdea {
  id               String            @id @default(uuid()) @db.Uuid
  communityId      String            @db.Uuid
  authorUserId     String            @db.Uuid
  mergedIntoIdeaId String?           @db.Uuid
  title            String
  summary          String
  description      String
  status           RoadmapIdeaStatus @default(SUBMITTED)
  staffNotes       String?
  publishedAt      DateTime?
  plannedAt        DateTime?
  startedAt        DateTime?
  shippedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  community   Community            @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author      User                 @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  mergedInto  RoadmapIdea?         @relation("roadmapIdeaMerge", fields: [mergedIntoIdeaId], references: [id], onDelete: SetNull)
  mergedIdeas RoadmapIdea[]        @relation("roadmapIdeaMerge")
  ballotItems RoadmapRankingItem[]

  @@index([communityId])
  @@index([authorUserId])
  @@index([status])
  @@index([mergedIntoIdeaId])
  @@map("roadmap_ideas")
}

enum RoadmapIdeaStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED_FOR_RANKING
  DECLINED
  MERGED
  PLANNED
  IN_PROGRESS
  SHIPPED
}

model RoadmapRankingBallot {
  id          String   @id @default(uuid()) @db.Uuid
  communityId String   @db.Uuid
  userId      String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  community Community            @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     RoadmapRankingItem[]

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@map("roadmap_ranking_ballots")
}

model RoadmapRankingItem {
  id       String @id @default(uuid()) @db.Uuid
  ballotId String @db.Uuid
  ideaId   String @db.Uuid
  rank     Int

  // Relations
  ballot RoadmapRankingBallot @relation(fields: [ballotId], references: [id], onDelete: Cascade)
  idea   RoadmapIdea          @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ballotId, rank])
  @@unique([ballotId, ideaId])
  @@index([ideaId])
  @@map("roadmap_ranking_items")
}

model DomainInfluenceWeight {
  id                String          @id @default(uuid()) @db.Uuid
  communityId       String          @db.Uuid
  userId            String          @db.Uuid
  domain            InfluenceDomain
  multiplierPercent Int             @default(100)
  rationale         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId, domain])
  @@index([communityId])
  @@index([userId])
  @@index([domain])
  @@map("domain_influence_weights")
}

enum InfluenceDomain {
  ROADMAP_FEATURE_PRIORITIZATION
}

// ============================================================================
// MARKETPLACE / STORES
// ============================================================================

model Store {
  id               String      @id @default(uuid()) @db.Uuid
  communityId      String      @db.Uuid
  ownerUserId      String      @db.Uuid
  approvedByUserId String?     @db.Uuid
  name             String
  slug             String
  description      String?
  logoUrl          String?
  bannerUrl        String?
  websiteUrl       String?
  contactEmail     String?
  contactPhone     String?
  status           StoreStatus @default(PENDING_APPROVAL)
  approvedAt       DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  community   Community            @relation(fields: [communityId], references: [id], onDelete: Cascade)
  owner       User                 @relation("storeOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  approvedBy  User?                @relation("storeApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  memberships StoreMember[]
  listings    MarketplaceListing[]

  @@unique([communityId, slug])
  @@index([communityId])
  @@index([ownerUserId])
  @@index([approvedByUserId])
  @@index([status])
  @@map("stores")
}

model StoreMember {
  id       String          @id @default(uuid()) @db.Uuid
  storeId  String          @db.Uuid
  userId   String          @db.Uuid
  role     StoreMemberRole @default(MANAGER)
  joinedAt DateTime        @default(now())

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([userId])
  @@map("store_members")
}

model MarketplaceListing {
  id            String                 @id @default(uuid()) @db.Uuid
  communityId   String                 @db.Uuid
  storeId       String                 @db.Uuid
  authorUserId  String                 @db.Uuid
  title         String
  description   String?
  priceCents    Int
  category      String
  listingType   MarketplaceListingType @default(PRODUCT)
  contactMethod String
  expiresAt     DateTime?
  status        MarketplaceStatus      @default(ACTIVE)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  // Relations
  community Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  store     Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  author    User               @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  photos    MarketplacePhoto[]

  @@index([communityId])
  @@index([storeId])
  @@index([authorUserId])
  @@index([status])
  @@map("marketplace_listings")
}

model MarketplacePhoto {
  id                   String @id @default(uuid()) @db.Uuid
  marketplaceListingId String @db.Uuid
  imageUrl             String
  sortOrder            Int    @default(0)

  // Relations
  marketplaceListing MarketplaceListing @relation(fields: [marketplaceListingId], references: [id], onDelete: Cascade)

  @@index([marketplaceListingId])
  @@map("marketplace_photos")
}

enum MarketplaceStatus {
  DRAFT
  PENDING
  ACTIVE
  SOLD
  ARCHIVED
  EXPIRED
  REMOVED
}

enum MarketplaceListingType {
  PRODUCT
  FOOD
  SERVICE
}

enum StoreStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

enum StoreMemberRole {
  OWNER
  MANAGER
}

// ============================================================================
// MESSAGING
// ============================================================================

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now())

  // Relations
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  userId         String   @db.Uuid
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  senderUserId   String   @db.Uuid
  body           String
  createdAt      DateTime @default(now())

  // Relations
  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  attachments  MessageAttachment[]

  @@index([conversationId])
  @@index([senderUserId])
  @@map("messages")
}

model MessageAttachment {
  id            String @id @default(uuid()) @db.Uuid
  messageId     String @db.Uuid
  fileUrl       String
  fileName      String
  fileType      String
  fileSizeBytes Int

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

// ============================================================================
// USER INTERACTIONS & BLOCKING
// ============================================================================

model UserBlock {
  id            String   @id @default(uuid()) @db.Uuid
  blockerUserId String   @db.Uuid
  blockedUserId String   @db.Uuid
  createdAt     DateTime @default(now())

  // Relations
  blocker User @relation("blockerUser", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked User @relation("blockedUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
  @@map("user_blocks")
}

// ============================================================================
// HOMEPAGE & SITE CONFIGURATION
// ============================================================================

model HomepageSection {
  id          String              @id @default(uuid()) @db.Uuid
  communityId String              @db.Uuid
  sectionType HomepageSectionType
  sortOrder   Int                 @default(0)
  isVisible   Boolean             @default(true)

  // Relations
  community   Community            @relation(fields: [communityId], references: [id], onDelete: Cascade)
  pinnedItems HomepagePinnedItem[]

  @@index([communityId])
  @@map("homepage_sections")
}

enum HomepageSectionType {
  FEATURED_ARTICLES
  LATEST_NEWS
  FEATURED_RECIPES
  UPCOMING_EVENTS
  RECENT_MARKETPLACE
  RECENT_GALLERIES
}

model HomepagePinnedItem {
  id                String      @id @default(uuid()) @db.Uuid
  homepageSectionId String      @db.Uuid
  contentType       ContentType
  contentId         String      @db.Uuid
  pinnedByUserId    String      @db.Uuid
  sortOrder         Int         @default(0)
  pinnedAt          DateTime    @default(now())

  // Relations
  homepageSection HomepageSection @relation(fields: [homepageSectionId], references: [id], onDelete: Cascade)
  pinnedBy        User            @relation(fields: [pinnedByUserId], references: [id], onDelete: Cascade)

  @@index([homepageSectionId])
  @@index([pinnedByUserId])
  @@map("homepage_pinned_items")
}

enum ContentType {
  ARTICLE
  RECIPE
  EVENT
  MARKETPLACE_LISTING
  GALLERY
}

model SiteSetting {
  id          String @id @default(uuid()) @db.Uuid
  communityId String @db.Uuid
  key         String
  value       String

  // Relations
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, key])
  @@index([communityId])
  @@map("site_settings")
}

// ============================================================================
// SECURITY & FORENSIC LOGGING
// ============================================================================

model LoginEvent {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  ipAddress     String
  userAgent     String?
  provider      String // "credentials", "google", "facebook"
  city          String?
  region        String?
  country       String?
  isAnomaly     Boolean  @default(false)
  anomalyReason String?
  createdAt     DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ipAddress])
  @@index([createdAt])
  @@index([userId, ipAddress])
  @@map("login_events")
}

model ActivityLog {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @db.Uuid
  action       ActivityAction
  resourceType ResourceType
  resourceId   String         @db.Uuid
  ipAddress    String?
  metadata     Json? // flexible field for extra context (e.g., changed fields, before/after)
  createdAt    DateTime       @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@index([action])
  @@map("activity_logs")
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  APPROVE
  REJECT
  FLAG
  SEND_MESSAGE
}

enum ResourceType {
  ARTICLE
  RECIPE
  COMMENT
  EVENT
  HELP_WANTED_POST
  ROADMAP_IDEA
  ROADMAP_RANKING_BALLOT
  DOMAIN_INFLUENCE_WEIGHT
  MARKETPLACE_LISTING
  MESSAGE
  CONVERSATION
  USER_PROFILE
}
