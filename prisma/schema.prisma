  ORGANIZATION
}

enum AnalyticsReferrerType {
  INTERNAL
  DIRECT
  SEARCH
  EXTERNAL
  UNKNOWN
}

enum ContentReactionType {
  useful
  important
  interesting
  needs_follow_up
}

model AnalyticsEvent {
  id                 String                @id @default(uuid()) @db.Uuid
  communityId        String?               @db.Uuid
  siteDomain         String?
  userId             String?               @db.Uuid
  sessionId          String
  anonymousVisitorId String?
  eventName          AnalyticsEventName
  contentType        AnalyticsContentType?
  contentId          String?
  pageType           String
  pagePath           String
  referrerType       AnalyticsReferrerType?
  referrerHost       String?
  occurredAt         DateTime              @default(now())
  metadata           Json?
  createdAt          DateTime              @default(now())

  community Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([communityId, occurredAt])
  @@index([contentType, contentId, occurredAt])
  @@index([eventName, occurredAt])
  @@index([sessionId, occurredAt])
  @@index([anonymousVisitorId, occurredAt])
  @@map("analytics_events")
}

model ContentReaction {
  id           String              @id @default(uuid()) @db.Uuid
  communityId  String?             @db.Uuid
  userId       String              @db.Uuid
  contentType  AnalyticsContentType
  contentId    String
  reactionType ContentReactionType
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  community Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentType, contentId])
  @@index([communityId, contentType, createdAt])
  @@index([contentType, contentId])
  @@map("content_reactions")
}

model ContentMetricsDaily {
  id             String               @id @default(uuid()) @db.Uuid
  communityId    String               @db.Uuid
  date           DateTime             @db.Date
  contentType    AnalyticsContentType
  contentId      String
  categoryLabel  String?
  authorUserId   String?              @db.Uuid
  pageViews      Int                  @default(0)
  uniqueVisitors Int                  @default(0)
  opens          Int                  @default(0)
  engagedPings   Int                  @default(0)
  reactions      Int                  @default(0)
  comments       Int                  @default(0)
  shares         Int                  @default(0)
  messageStarts  Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User?     @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@unique([communityId, date, contentType, contentId])
  @@index([communityId, date, contentType])
  @@index([authorUserId, date])
  @@map("content_metrics_daily")
}

model CategoryMetricsDaily {
  id            String               @id @default(uuid()) @db.Uuid
  communityId   String               @db.Uuid
  date          DateTime             @db.Date
  contentType   AnalyticsContentType
  categoryLabel String
  pageViews     Int                  @default(0)
  uniqueVisitors Int                 @default(0)
  opens         Int                  @default(0)
  engagedPings  Int                  @default(0)
  reactions     Int                  @default(0)
  comments      Int                  @default(0)
  shares        Int                  @default(0)
  messageStarts Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, date, contentType, categoryLabel])
  @@index([communityId, date, contentType])
  @@map("category_metrics_daily")
}

model HomepageSlotMetricsDaily {
  id           String               @id @default(uuid()) @db.Uuid
  communityId  String               @db.Uuid
  date         DateTime             @db.Date
  slotPosition Int
  boxType      String
  placement    String
  contentType  AnalyticsContentType?
  contentId    String?
  impressions  Int                  @default(0)
  clicks       Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, date, slotPosition, boxType, placement, contentType, contentId])
  @@index([communityId, date, boxType])
  @@map("homepage_slot_metrics_daily")
}
