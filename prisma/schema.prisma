model Store {
  id               String      @id @default(uuid()) @db.Uuid
  communityId      String      @db.Uuid
  ownerUserId      String      @db.Uuid
  approvedByUserId String?     @db.Uuid
  name             String
  slug             String
  description      String?
  logoUrl          String?
  bannerUrl        String?
  websiteUrl       String?
  contactEmail     String?
  contactPhone     String?
  status           StoreStatus @default(PENDING_APPROVAL)
