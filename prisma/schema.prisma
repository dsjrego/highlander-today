// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE COMMUNITY & USER MODELS
// ============================================================================

model Community {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  slug         String   @unique
  domain       String?  @unique
  description  String?
  colorPrimary String   @default("var(--brand-primary)")
  colorAccent  String   @default("var(--brand-accent)")
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  memberships            UserCommunityMembership[]
  articles               Article[]
  recipes                Recipe[]
  events                 Event[]
  eventSeries            EventSeries[]
  stores                 Store[]
  organizations          Organization[]
  organizationFormSubmissions OrganizationFormSubmission[]
  locations              Location[]
  marketplaceListings    MarketplaceListing[]
  helpWantedPosts        HelpWantedPost[]
  roadmapIdeas           RoadmapIdea[]
  roadmapBallots         RoadmapRankingBallot[]
  domainInfluenceWeights DomainInfluenceWeight[]
  homepageBoxes          HomepageBox[]
  homepageSectionsLegacy HomepageSectionLegacy[]
  domains                TenantDomain[]
  reporterRuns           ReporterRun[]
  categories             Category[]
  memorialPeople         MemorialPerson[]
  memorialPages          MemorialPage[]
  memorialSubmissions    MemorialSubmission[]
  memorialMemories       MemorialMemory[]
  memorialPhotos         MemorialPhoto[]
  memorialAuditLogs      MemorialAuditLog[]
  siteSettings           SiteSetting[]
  tenantCoverageAreas    TenantCoverageArea[]
  analyticsEvents        AnalyticsEvent[]
  contentReactions       ContentReaction[]
  contentMetricsDaily    ContentMetricsDaily[]
  categoryMetricsDaily   CategoryMetricsDaily[]
  homepageSlotMetricsDaily HomepageSlotMetricsDaily[]

  @@map("communities")
}

model TenantDomain {
  id          String             @id @default(uuid()) @db.Uuid
  communityId String             @db.Uuid
  domain      String             @unique
  isPrimary   Boolean            @default(false)
  status      TenantDomainStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@map("tenant_domains")
}

enum TenantDomainStatus {
  PENDING
  ACTIVE
  DISABLED
}

model User {
  id                String     @id @default(uuid()) @db.Uuid
  email             String     @unique
  passwordHash      String?
  firstName         String
  lastName          String
  dateOfBirth       DateTime?
  profilePhotoUrl   String?
  bio               String?
  isDirectoryListed Boolean    @default(false)
  trustLevel        TrustLevel @default(ANONYMOUS)
  isIdentityLocked  Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  memberships              UserCommunityMembership[]
  vouchesGiven             VouchRecord[]             @relation("voucherUser")
  vouchesReceived          VouchRecord[]             @relation("vouchedUser")
  articles                 Article[]
  recipes                  Recipe[]
  comments                 Comment[]
  eventsSubmitted          Event[]
  eventSeriesCreated       EventSeries[]
  marketplaceListings      MarketplaceListing[]
  helpWantedPosts          HelpWantedPost[]
  roadmapIdeas             RoadmapIdea[]
  roadmapRankingBallots    RoadmapRankingBallot[]
  domainInfluenceWeights   DomainInfluenceWeight[]
  trustAuditLogsAsActor    TrustAuditLog[]           @relation("actorUser")
  trustAuditLogsAsTarget   TrustAuditLog[]           @relation("targetUser")
  bannedEmailsCreated      BannedEmail[]             @relation("bannedByUser")
  bannedEmailsRemoved      BannedEmail[]             @relation("unbannedByUser")
  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]
  userBlocksInitiated      UserBlock[]               @relation("blockerUser")
  userBlocksReceived       UserBlock[]               @relation("blockedUser")
  homepageBoxItems         HomepageBoxItem[]
  homepagePinnedItemsLegacy HomepagePinnedItemLegacy[]
  loginEvents              LoginEvent[]
  activityLogs             ActivityLog[]
  ownedStores              Store[]                   @relation("storeOwner")
  approvedStores           Store[]                   @relation("storeApprovedBy")
  storeMemberships         StoreMember[]
  createdOrganizations     Organization[]            @relation("organizationCreatedBy")
  approvedOrganizations    Organization[]            @relation("organizationApprovedBy")
  organizationMemberships  OrganizationMembership[]
  organizationContacts     OrganizationContact[]
  createdOrganizationForms OrganizationForm[]        @relation("organizationFormCreatedBy")
  updatedOrganizationForms OrganizationForm[]        @relation("organizationFormUpdatedBy")
  organizationFormSubmissions OrganizationFormSubmission[]
  placeRelationships       UserPlaceRelationship[]
  reporterRunsCreated      ReporterRun[]             @relation("reporterRunCreatedBy")
  reporterRunsAssigned     ReporterRun[]             @relation("reporterRunAssignedTo")
  reporterSourcesCreated   ReporterSource[]          @relation("reporterSourceCreatedBy")
  reporterDraftsCreated    ReporterDraft[]           @relation("reporterDraftCreatedBy")
  reporterBlockersResolved ReporterBlocker[]         @relation("reporterBlockerResolvedBy")
  reporterInterviewRequestsCreated ReporterInterviewRequest[] @relation("reporterInterviewRequestCreatedBy")
  reporterInterviewRequestsAsSubject ReporterInterviewRequest[] @relation("reporterInterviewRequestInterviewee")
  reporterInterviewSessionsReviewed ReporterInterviewSession[] @relation("reporterInterviewSessionReviewedBy")
  memorialPageCreations  MemorialPage[]            @relation("memorialPageCreatedBy")
  memorialPageApprovals  MemorialPage[]            @relation("memorialPageApprovedBy")
  memorialSubmissionsCreated MemorialSubmission[]  @relation("memorialSubmissionCreatedBy")
  memorialSubmissionsAssigned MemorialSubmission[] @relation("memorialSubmissionAssignedTo")
  memorialSubmissionsReviewed MemorialSubmission[] @relation("memorialSubmissionReviewedBy")
  memorialContributorUsers MemorialContributor[]   @relation("memorialContributorUser")
  memorialContributorInvites MemorialContributor[] @relation("memorialContributorInvitedBy")
  memorialVerificationsCreated MemorialVerification[] @relation("memorialVerificationCreatedBy")
  memorialMemoriesCreated MemorialMemory[]         @relation("memorialMemoryCreatedBy")
  memorialMemoriesReviewed MemorialMemory[]        @relation("memorialMemoryReviewedBy")
  memorialPhotosCreated   MemorialPhoto[]          @relation("memorialPhotoCreatedBy")
  memorialPhotosReviewed  MemorialPhoto[]          @relation("memorialPhotoReviewedBy")
  memorialAuditLogsActor  MemorialAuditLog[]       @relation("memorialAuditActor")
  analyticsEvents             AnalyticsEvent[]
  contentReactions            ContentReaction[]
  authoredContentMetricsDaily ContentMetricsDaily[]

  @@map("users")
}

enum TrustLevel {
  ANONYMOUS
  REGISTERED
  TRUSTED
  SUSPENDED
}

enum OrganizationDirectoryGroup {
  BUSINESS
  GOVERNMENT
  ORGANIZATION
}

enum OrganizationStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrganizationMembershipRole {
  OWNER
  MANAGER
  STAFF
  BOARD_MEMBER
  VOLUNTEER
  PASTOR
  OFFICIAL
  ADMINISTRATOR
}

enum OrganizationMembershipStatus {
  PENDING
  ACTIVE
  REJECTED
  REMOVED
}

enum OrganizationFormStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum OrganizationFormQuestionType {
  TEXT_SHORT
  TEXT_LONG
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}

// ============================================================================
// COMMUNITY MEMBERSHIP & TRUST
// ============================================================================

model UserCommunityMembership {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  communityId String         @db.Uuid
  role        MembershipRole @default(READER)
  joinedAt    DateTime       @default(now())

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@map("user_community_memberships")
}

enum MembershipRole {
  READER
  CONTRIBUTOR
  STAFF_WRITER
  EDITOR
  ADMIN
  SUPER_ADMIN
}

enum PlaceType {
  BOROUGH
  TOWNSHIP
  TOWN
  CITY
  COUNTY
  REGION
  STATE
  COUNTRY
}

enum TenantCoverageType {
  PRIMARY
  SECONDARY
  EMERGING
  WATCHLIST
}

enum UserPlaceRelationshipType {
  CURRENT_RESIDENT
  FORMER_RESIDENT
  FROM_HERE
  FAMILY_IN
  WORKS_IN
  OWNS_PROPERTY_IN
  CARES_ABOUT
}

enum UserPlaceSource {
  USER_SELECTED
  ADMIN_SET
  MIGRATED
}

enum ObservedGeoReviewStatus {
  UNMATCHED
  MATCHED_TO_PLACE
  IGNORE
  READY_FOR_CURATION
  PROMOTED
}

model Place {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  displayName    String
  slug           String    @unique
  type           PlaceType
  countryCode    String
  admin1Code     String?
  admin1Name     String?
  admin2Name     String?
  parentPlaceId  String?   @db.Uuid
  isSelectable   Boolean   @default(true)
  isActive       Boolean   @default(true)
  latitude       Decimal?  @db.Decimal(9, 6)
  longitude      Decimal?  @db.Decimal(9, 6)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  parentPlace            Place?                  @relation("PlaceHierarchy", fields: [parentPlaceId], references: [id], onDelete: SetNull)
  childPlaces            Place[]                 @relation("PlaceHierarchy")
  aliases                PlaceAlias[]
  tenantCoverageAreas    TenantCoverageArea[]
  userRelationships      UserPlaceRelationship[]
  matchedObservedGeos    ObservedGeoLocation[]
  reporterSources        ReporterSource[]        @relation("reporterSourcePlace")

  @@index([type])
  @@index([countryCode])
  @@index([parentPlaceId])
  @@index([countryCode, admin1Code])
  @@map("places")
}

model PlaceAlias {
  id           String   @id @default(uuid()) @db.Uuid
  placeId      String   @db.Uuid
  alias        String
  aliasType    String?
  isSearchable Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, alias])
  @@index([placeId])
  @@index([alias])
  @@map("place_aliases")
}

model TenantCoverageArea {
  id           String             @id @default(uuid()) @db.Uuid
  communityId  String             @db.Uuid
  placeId      String             @db.Uuid
  coverageType TenantCoverageType @default(SECONDARY)
  isPrimary    Boolean            @default(false)
  isActive     Boolean            @default(true)
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  // Relations
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  place     Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([communityId, placeId])
  @@index([communityId])
  @@index([placeId])
  @@index([coverageType])
  @@map("tenant_coverage_areas")
}

model UserPlaceRelationship {
  id                   String                    @id @default(uuid()) @db.Uuid
  userId               String                    @db.Uuid
  placeId              String?                   @db.Uuid
  relationshipType     UserPlaceRelationshipType
  isPrimary            Boolean                   @default(false)
  isCurrent            Boolean                   @default(false)
  fallbackLocationText String?
  source               UserPlaceSource           @default(USER_SELECTED)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place? @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([placeId])
  @@index([relationshipType])
  @@map("user_place_relationships")
}

model ObservedGeoLocation {
  id                String                  @id @default(uuid()) @db.Uuid
  normalizedLabel   String
  city              String?
  region            String?
  country           String?
  matchedPlaceId    String?                 @db.Uuid
  reviewStatus      ObservedGeoReviewStatus @default(UNMATCHED)
  firstSeenAt       DateTime
  lastSeenAt        DateTime
  loginCount        Int                     @default(0)
  distinctUserCount Int                     @default(0)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  // Relations
  matchedPlace Place? @relation(fields: [matchedPlaceId], references: [id], onDelete: SetNull)

  @@unique([normalizedLabel])
  @@index([matchedPlaceId])
  @@index([reviewStatus])
  @@map("observed_geo_locations")
}

model VouchRecord {
  id            String   @id @default(uuid()) @db.Uuid
  voucherUserId String   @db.Uuid
  vouchedUserId String   @db.Uuid
  createdAt     DateTime @default(now())

  // Relations
  voucherUser User @relation("voucherUser", fields: [voucherUserId], references: [id], onDelete: Cascade)
  vouchedUser User @relation("vouchedUser", fields: [vouchedUserId], references: [id], onDelete: Cascade)

  @@unique([voucherUserId, vouchedUserId])
  @@map("vouch_records")
}

model TrustAuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  actorUserId  String      @db.Uuid
  targetUserId String      @db.Uuid
  action       TrustAction
  reason       String?
  timestamp    DateTime    @default(now())

  // Relations
  actorUser  User @relation("actorUser", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUser User @relation("targetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@map("trust_audit_logs")
}

enum TrustAction {
  TRUST_GRANTED
  TRUST_REVOKED
  SUSPENDED
  REINSTATED
  BANNED
  UNBANNED
  IDENTITY_MODIFIED
}

model BannedEmail {
  id               String    @id @default(uuid()) @db.Uuid
  email            String    @unique
  bannedByUserId   String    @db.Uuid
  bannedAt         DateTime  @default(now())
  unbannedByUserId String?   @db.Uuid
  unbannedAt       DateTime?

  // Relations
  bannedByUser   User  @relation("bannedByUser", fields: [bannedByUserId], references: [id], onDelete: Cascade)
  unbannedByUser User? @relation("unbannedByUser", fields: [unbannedByUserId], references: [id], onDelete: SetNull)

  @@map("banned_emails")
}

// ============================================================================
// DIRECTORY / ORGANIZATIONS
// ============================================================================

model Organization {
  id                   String                     @id @default(uuid()) @db.Uuid
  communityId          String                     @db.Uuid
  createdByUserId      String                     @db.Uuid
  approvedByUserId     String?                    @db.Uuid
  name                 String
  slug                 String
  description          String?
  logoUrl              String?
  bannerUrl            String?
  websiteUrl           String?
  contactEmail         String?
  contactPhone         String?
  directoryGroup       OrganizationDirectoryGroup
  organizationType     String
  isPublicMemberRoster Boolean                    @default(false)
  status               OrganizationStatus         @default(PENDING_APPROVAL)
  approvedAt           DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  // Relations
  community   Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdBy   User                     @relation("organizationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  approvedBy  User?                    @relation("organizationApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  memberships OrganizationMembership[]
  locations   OrganizationLocation[]
  departments OrganizationDepartment[]
  contacts    OrganizationContact[]
  events      Event[]
  eventSeries EventSeries[]
  forms       OrganizationForm[]
  formSubmissions OrganizationFormSubmission[]
  reporterSources ReporterSource[] @relation("reporterSourceOrganization")

  @@unique([communityId, slug])
  @@index([communityId])
  @@index([createdByUserId])
  @@index([approvedByUserId])
  @@index([directoryGroup])
  @@index([organizationType])
  @@index([status])
  @@map("organizations")
}

model OrganizationMembership {
  id               String                       @id @default(uuid()) @db.Uuid
  organizationId   String                       @db.Uuid
  userId           String                       @db.Uuid
  role             OrganizationMembershipRole   @default(MANAGER)
  status           OrganizationMembershipStatus @default(PENDING)
  title            String?
  isPublic         Boolean                      @default(false)
  isPrimaryContact Boolean                      @default(false)
  joinedAt         DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@map("organization_memberships")
}

model OrganizationLocation {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  label          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  municipality   String?
  contactEmail   String?
  contactPhone   String?
  websiteUrl     String?
  hoursSummary   String?
  isPrimary      Boolean  @default(false)
  isPublic       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments  OrganizationDepartment[]
  contacts     OrganizationContact[]

  @@index([organizationId])
  @@index([municipality])
  @@map("organization_locations")
}

model OrganizationDepartment {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  locationId     String?  @db.Uuid
  name           String
  slug           String?
  description    String?
  contactEmail   String?
  contactPhone   String?
  websiteUrl     String?
  hoursSummary   String?
  isPublic       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     OrganizationLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  contacts     OrganizationContact[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([locationId])
  @@map("organization_departments")
}

model OrganizationContact {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  departmentId   String?  @db.Uuid
  locationId     String?  @db.Uuid
  userId         String?  @db.Uuid
  label          String?
  name           String?
  title          String?
  email          String?
  phone          String?
  websiteUrl     String?
  isPublic       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department   OrganizationDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  location     OrganizationLocation?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  user         User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([departmentId])
  @@index([locationId])
  @@index([userId])
  @@map("organization_contacts")
}

model OrganizationForm {
  id                String                 @id @default(uuid()) @db.Uuid
  organizationId    String                 @db.Uuid
  createdByUserId   String                 @db.Uuid
  updatedByUserId   String?                @db.Uuid
  title             String
  slug              String
  description       String?
  status            OrganizationFormStatus @default(DRAFT)
  isPubliclyListed  Boolean                @default(false)
  minimumTrustLevel TrustLevel             @default(REGISTERED)
  opensAt           DateTime?
  closesAt          DateTime?
  publishedAt       DateTime?
  closedAt          DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  organization Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User                        @relation("organizationFormCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  updatedBy    User?                       @relation("organizationFormUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  questions    OrganizationFormQuestion[]
  submissions  OrganizationFormSubmission[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("organization_forms")
}

model OrganizationFormQuestion {
  id         String                       @id @default(uuid()) @db.Uuid
  formId     String                       @db.Uuid
  prompt     String
  helpText   String?
  type       OrganizationFormQuestionType
  isRequired Boolean                      @default(false)
  sortOrder  Int                          @default(0)
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt

  form    OrganizationForm                 @relation(fields: [formId], references: [id], onDelete: Cascade)
  options OrganizationFormQuestionOption[]
  answers OrganizationFormAnswer[]

  @@index([formId, sortOrder])
  @@map("organization_form_questions")
}

model OrganizationFormQuestionOption {
  id         String                 @id @default(uuid()) @db.Uuid
  questionId String                 @db.Uuid
  label      String
  value      String
  sortOrder  Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  question OrganizationFormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  OrganizationFormAnswer[]

  @@index([questionId, sortOrder])
  @@map("organization_form_question_options")
}

model OrganizationFormSubmission {
  id             String   @id @default(uuid()) @db.Uuid
  formId         String   @db.Uuid
  organizationId String   @db.Uuid
  userId         String?  @db.Uuid
  communityId    String   @db.Uuid
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  form         OrganizationForm       @relation(fields: [formId], references: [id], onDelete: Cascade)
  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  community    Community              @relation(fields: [communityId], references: [id], onDelete: Cascade)
  answers      OrganizationFormAnswer[]

  @@index([formId, userId])
  @@index([organizationId, submittedAt])
  @@map("organization_form_submissions")
}

model OrganizationFormAnswer {
  id               String   @id @default(uuid()) @db.Uuid
  submissionId     String   @db.Uuid
  questionId       String   @db.Uuid
  selectedOptionId String?  @db.Uuid
  textValue        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  submission     OrganizationFormSubmission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question       OrganizationFormQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption OrganizationFormQuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@index([submissionId])
  @@index([questionId])
  @@index([selectedOptionId])
  @@map("organization_form_answers")
}

// ============================================================================
// ARTICLES & CONTENT
// ============================================================================

model Article {
  id                   String        @id @default(uuid()) @db.Uuid
  communityId          String        @db.Uuid
  authorUserId         String        @db.Uuid
  title                String
  slug                 String
  excerpt              String?
  body                 String
  featuredImageUrl     String?
  featuredImageCaption String?       @map("featured_image_caption")
  status               ArticleStatus @default(DRAFT)
  categoryId           String?       @db.Uuid
  publishedAt          DateTime?
  isFeatured           Boolean       @default(false)
  featuredOrder        Int?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relations
  community Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User         @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  category  Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags      ArticleTag[]
  comments  Comment[]
  reporterRunLinks ReporterRun[]    @relation("reporterRunLinkedArticle")
  reporterSources  ReporterSource[] @relation("reporterSourceArticle")

  @@unique([communityId, slug])
  @@index([communityId])
  @@index([authorUserId])
  @@index([categoryId])
  @@index([status])
  @@map("articles")
}

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  UNPUBLISHED
}

enum ReporterRunStatus {
  NEW
  NEEDS_REVIEW
  SOURCE_PACKET_IN_PROGRESS
  READY_FOR_DRAFT
  BLOCKED
  DRAFT_CREATED
  CONVERTED_TO_ARTICLE
  ARCHIVED
}

enum ReporterMode {
  REQUEST
  INTERVIEW
  RESEARCH
  HYBRID
}

enum ReporterRequestType {
  ARTICLE_REQUEST
  STORY_TIP
  EDITOR_ASSIGNMENT
}

enum ReporterSourceType {
  USER_NOTE
  STAFF_NOTE
  INTERVIEW_NOTE
  TRANSCRIPT_EXCERPT
  DOCUMENT
  OFFICIAL_URL
  NEWS_ARTICLE
  HIGHLANDER_ARTICLE
  EVENT_RECORD
  ORGANIZATION_RECORD
  PLACE_RECORD
}

enum ReporterReliabilityTier {
  PRIMARY
  HIGH
  MEDIUM
  LOW
  UNVERIFIED
}

enum ReporterValidationSeverity {
  CRITICAL
  WARNING
}

