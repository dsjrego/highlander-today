{
  "name": "highlander-today",
  "version": "1.0.0",
  "description": "A multi-tenant community news platform",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate --schema prisma/schema.prisma",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathPattern='tests/unit'",
    "test:integration": "jest --testPathPattern='tests/integration'",
    "test:e2e": "jest --testPathPattern='tests/e2e'",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:create-super-admin": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/create-super-admin.ts",
    "db:set-user-dob": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/set-user-dob.ts",
    "deploy:check-env": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/check-deployment-env.ts",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^1.0.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-image": "^2.1.0",
    "@tiptap/extension-link": "^2.1.0",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/react": "^2.1.0",
    "@tiptap/starter-kit": "^2.1.0",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.4.16",
    "bcryptjs": "^2.4.3",
    "d3": "^7.8.5",
    "date-fns": "^2.30.0",
    "isomorphic-dompurify": "^3.4.0",
    "lucide-react": "^0.309.0",
    "next": "^14.0.0",
    "next-auth": "^4.24.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-calendar": "^4.2.1",
    "react-dom": "^18.2.0",
    "sanitize-html": "^2.17.1",
    "sharp": "^0.33.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/d3": "^7.4.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.37",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "prisma": "^5.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
